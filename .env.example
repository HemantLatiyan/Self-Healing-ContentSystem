# Supabase project (cloud) — Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# New API key naming (replaces NEXT_PUBLIC_SUPABASE_ANON_KEY). Starts with `sb_publishable_`.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Service role key (Settings → API → Project API keys). Bypasses RLS — server-only.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Postgres connection string — Settings → Database → Connection string (URI, Session pooler is fine).
DATABASE_URL=postgresql://postgres.YOUR-PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...
# Optional: override model. Default is gemini-2.5-flash.
# GEMINI_MODEL=gemini-2.5-flash

# Auto-heal cutoff — proposals at or above this confidence publish without review.
AUTO_HEAL_THRESHOLD=0.85

# Optional. If set, external callers of /api/cron/{scan,process} must send
# `Authorization: Bearer <CRON_SECRET>`. Same-origin UI requests (the Scan/Process
# buttons) are always allowed. Leave unset for local dev.
# CRON_SECRET=
